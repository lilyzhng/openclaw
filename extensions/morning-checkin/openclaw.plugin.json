{
  "id": "morning-checkin",
  "name": "Morning Check-in",
  "description": "Scheduled morning voice call check-in.",
  "uiHints": {
    "time": {
      "label": "Check-in Time",
      "help": "24h format, e.g. '08:00'. Default: 08:00."
    },
    "tz": {
      "label": "Timezone",
      "help": "IANA timezone, e.g. 'America/New_York'. Default: UTC."
    },
    "toNumber": {
      "label": "Phone Number",
      "placeholder": "+15550001234"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "time": {
        "type": "string",
        "pattern": "^[0-2]?\\d:[0-5]\\d$"
      },
      "tz": {
        "type": "string"
      },
      "toNumber": {
        "type": "string",
        "pattern": "^\\+[1-9]\\d{1,14}$"
      },
      "maxCallDurationMin": {
        "type": "integer",
        "minimum": 1,
        "maximum": 60
      }
    }
  }
}
